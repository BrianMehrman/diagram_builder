{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.4.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Diagram Builder Parser — parse run rate, duration, file throughput, and error metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "API Overview",
      "url": "/d/diagram-builder-api",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    }
  ],
  "panels": [
    {
      "id": 1,
      "title": "Parse Run Rate (files/s by language)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (language) (rate(parser_files_total[5m]))",
          "legendFormat": "{{language}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "axisLabel": "files/s" }
        }
      }
    },
    {
      "id": 2,
      "title": "Parse Duration p50 / p95 by Phase",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, phase) (rate(parser_run_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{phase}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, phase) (rate(parser_run_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{phase}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "axisLabel": "duration (s)" }
        }
      }
    },
    {
      "id": 3,
      "title": "Files by Status (parsed / skipped / error)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (status) (rate(parser_files_total[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "axisLabel": "files/s" }
        }
      }
    },
    {
      "id": 4,
      "title": "Parse Error Rate by Error Type",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum by (error_type) (rate(parser_errors_total[5m]))",
          "legendFormat": "{{error_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "axisLabel": "errors/s" }
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["diagram-builder", "parser"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Diagram Builder — Parser Overview",
  "uid": "diagram-builder-parser",
  "version": 1
}
