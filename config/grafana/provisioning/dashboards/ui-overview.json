{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.4.0" },
    { "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Diagram Builder UI — browser error rates sourced from Loki logs",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "API Overview",
      "url": "/d/diagram-builder-api",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Parser Overview",
      "url": "/d/diagram-builder-parser",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    }
  ],
  "panels": [
    {
      "id": 1,
      "title": "UI Error Rate (browser errors/s)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate({app=\"diagram-builder-ui\"} | json | level=\"error\" [5m]))",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "axisLabel": "errors/s" }
        }
      }
    },
    {
      "id": 2,
      "title": "UI Error Log Stream",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "{app=\"diagram-builder-ui\"} | json | level=\"error\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["diagram-builder", "ui"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Diagram Builder — UI Overview",
  "uid": "diagram-builder-ui",
  "version": 1
}
